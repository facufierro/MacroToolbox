{
    "$schema":  "https://schema.tauri.app/config/2",
    "productName":  "Hotkey Manager",
    "version":  "1.6.4",
    "identifier":  "com.fierro.hotkey-manager",
    "build":  {
                  "beforeDevCommand":  "npm run dev",
                  "devUrl":  "http://localhost:1420",
                  "beforeBuildCommand":  "npm run build",
                  "frontendDist":  "../dist"
              },
    "app":  {
                "windows":  [
                                {
                                    "title":  "Hotkey Manager",
                                    "width":  1100,
                                    "height":  700,
                                    "minWidth":  800,
                                    "minHeight":  500,
                                    "maximized":  true,
                                    "visible":  false
                                }
                            ],
                "security":  {
                                 "csp":  null
                             }
            },
    "bundle":  {
                   "active":  true,
                   "targets":  "all",
                   "resources":  [
                                     "resources/**/*"
                                 ],
                   "icon":  [
                                "icons/32x32.png",
                                "icons/128x128.png",
                                "icons/128x128@2x.png",
                                "icons/icon.icns",
                                "icons/icon.ico"
                            ]
               }
}
