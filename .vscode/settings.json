{
    "quickCommandButtons.buttons": [
        {
            "name": "$(play) Run Dev",
            "color": "#7c6af7",
            "command": "Start-Process powershell -Verb RunAs -ArgumentList '-NoProfile -NoExit -ExecutionPolicy Bypass -File D:\\Projects\\Games\\HotkeyManager\\dev.ps1'",
            "terminalName": "Dev"
        },
        {
            "name": "$(package) Build",
            "color": "#4ade80",
            "command": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\scripts\\package-release.ps1",
            "terminalName": "Build"
        },
        {
            "name": "$(rocket) Open Releases",
            "color": "#38bdf8",
            "command": "Start-Process 'https://github.com/facufierro/HotkeyManager/releases/latest'",
            "terminalName": "Releases"
        }
    ]
}
